# Chat2Cash environment template.
# Copy to .env on the host and fill real secrets there. Never commit live values.

# Runtime
NODE_ENV=production
PORT=4001
DATA_DIR=/opt/mw/chat2cash-data

# Public origin used by Better Auth redirects and app origin checks.
# Local dev: http://localhost:4001
# Production: https://chat2cash.mindwaveja.com
APP_URL=https://chat2cash.mindwaveja.com
BETTER_AUTH_URL=https://chat2cash.mindwaveja.com

# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# AI evaluation providers. RunPod is tried first when both RunPod values exist.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
DEEPSEEK_API_KEY=

# WiPay payout operations. Text-chat payout settlement is JMD for launch.
WIPAY_ACCOUNT_NUMBER=
WIPAY_MERCHANT_KEY=
WIPAY_COUNTRY_CODE=JM

# Legacy admin fallback should stay unset in production.
ADMIN_PASSPHRASE=
ADMIN_CLICK_SEQUENCE=["V1","V3","V2","V1","V3"]
ADMIN_EMAIL=admin@chat2cash.internal

# Optional test-account seeding. Set only when running `pnpm seed:test-accounts`.
TEST_ACCOUNT_PASSWORD=
TEST_CONTRIBUTOR_EMAIL=testin@chat2cash.local
TEST_ADMIN_EMAIL=testin-admin@chat2cash.local

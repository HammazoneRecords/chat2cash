# DEEPSEEK_API_KEY: Required for DeepSeek AI evaluation.
# Load from ark.local in MW_CENTRAL. Never commit the actual key.
DEEPSEEK_API_KEY=""

# APP_URL: The URL where this app is hosted (e.g. https://purifier.mindwaveja.com).
APP_URL="MY_APP_URL"

# WIPAY_ACCOUNT_NUMBER: WiPay merchant account number (e.g. 123456789)
WIPAY_ACCOUNT_NUMBER=""

# WIPAY_MERCHANT_KEY: WiPay API merchant key/payout secret key
WIPAY_MERCHANT_KEY=""

# WIPAY_COUNTRY_CODE: Country code for payout market (TT, JAM, BB, etc.)
WIPAY_COUNTRY_CODE="TT"

# Better Auth
BETTER_AUTH_SECRET=generate-with: node -e "console.log(require(crypto).randomBytes(32).toString(hex))"
BETTER_AUTH_URL=https://your-domain.com
